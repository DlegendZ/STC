# -----------------------------------------------
# NEVER commit this file to GitHub or share it!
# Add .env to your .gitignore immediately.
# -----------------------------------------------

# Your MetaMask wallet private key
# How to export: MetaMask → Account → three dots → Account Details → Export Private Key
# IMPORTANT: Use a dedicated dev wallet, NOT your main wallet
PRIVATE_KEY=your_metamask_private_key_here

# Alchemy RPC URL for Sepolia
# Get it free at: https://alchemy.com → Create App → Ethereum → Sepolia
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here

# Etherscan API Key (for contract verification)
# Get it free at: https://etherscan.io → Sign up → API Keys → Add
ETHERSCAN_API_KEY=your_etherscan_api_key_here
